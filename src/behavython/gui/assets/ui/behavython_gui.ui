                 <string notr="true">/* Base button */
QPushButton {
    font: 8pt &quot;Arial&quot;;
    font-weight: bold;

    border: 2px solid #A21F27;
    border-radius: 8px;

    background-color: #2C53A1;
    color: #FFFFFF;
}

/* Hover */
QPushButton:hover {
    background-color: #3A63B8; /* slightly lighter than base */
}

/* Pressed */
QPushButton:pressed {
    background-color: #A21F27;
    color: #FFFFFF;
}

QPushButton:disabled {
    background-color: gray;
    color: white;
    border: 2px solid darkgray;
}</string>
