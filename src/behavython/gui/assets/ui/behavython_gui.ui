             </property>
             <property name="title">
              <string>NETWORK SETTINGS</string>
             </property>
             <property name="alignment">
              <set>Qt::AlignmentFlag::AlignCenter</set>
             </property>
             <layout class="QGridLayout" name="gridLayout_9">
              <property name="rightMargin">
               <number>9</number>
              </property>
              <property name="spacing">
               <number>6</number>
              </property>
              <item row="2" column="0" colspan="4">
               <widget class="QCheckBox" name="use_default_network_button">
                <property name="sizePolicy">
                 <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                  <horstretch>0</horstretch>
                  <verstretch>0</verstretch>
                 </sizepolicy>
                </property>
                <property name="minimumSize">
                 <size>
                  <width>281</width>
                  <height>16</height>
                 </size>
                </property>
                <property name="cursor">
                 <cursorShape>WhatsThisCursor</cursorShape>
                </property>
                <property name="toolTip">
                 <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400;&quot;&gt;Enable this option to use the built-in pretrained DeepLabCut network provided with Behavython.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400;&quot;&gt;This model is specifically optimized for tracking &lt;b&gt;C57BL/6 mice&lt;/b&gt; recorded from an &lt;b&gt;overhead (top-down) view&lt;/b&gt; in a &lt;b&gt;white arena&lt;/b&gt;, and supports both animal pose estimation and ROI detection.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400;&quot;&gt;The pretrained models are distributed via Behavython releases and must be downloaded and extracted before use.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;Example model files:&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;- c57_network_2025_minified.zip (mouse tracking)&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;- roi_network.zip (region of interest detection)&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400;&quot;&gt;After downloading, extract the contents into the Behavython models directory:&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;Windows: C:\Users\YourUsername\.behavython\models\&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;Linux/Mac: ~/.behavython/models/&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;Important: Ensure that the model files are placed directly inside the &lt;b&gt;models&lt;/b&gt; folder (not inside additional nested subfolders).&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style=&quot; font-size:8pt; font-weight:400; font-style:italic;&quot;&gt;Use this option only if your experimental setup closely matches these conditions. Otherwise, provide your own DeepLabCut config.yaml.&lt;/span&gt;&lt;/p&gt;

&lt;/body&gt;&lt;/html&gt;</string>
                </property>
                <property name="styleSheet">
