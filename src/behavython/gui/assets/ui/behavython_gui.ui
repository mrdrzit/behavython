  <property name="styleSheet">
   <string notr="true">QWidget {
    background-color: #4B4B4B;
    color: #FFFFFF;
}

/* =========================================
   VERTICAL SCROLLBAR
   ========================================= */
QScrollBar:vertical {
    border: none;
    background: #2b2b2b; /* Track background */
    width: 12px;
    margin: 0px;
    border-radius: 6px;
}

/* The slider handle */
QScrollBar::handle:vertical {
    background: #5c5c5c;
    min-height: 30px;
    border-radius: 6px;
}

QScrollBar::handle:vertical:hover {
    background: #7a7a7a;
}

QScrollBar::handle:vertical:pressed {
    background: #3a539b; /* Accent blue */
}

/* Hide the up/down arrow buttons */
QScrollBar::sub-line:vertical, QScrollBar::add-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

/* Make the track area above and below the handle transparent */
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* =========================================
   HORIZONTAL SCROLLBAR
   ========================================= */
QScrollBar:horizontal {
    border: none;
    background: #2b2b2b;
    height: 12px;
    margin: 0px;
    border-radius: 6px;
}

QScrollBar::handle:horizontal {
    background: #5c5c5c;
    min-width: 30px;
    border-radius: 6px;
}

QScrollBar::handle:horizontal:hover {
    background: #7a7a7a;
}

QScrollBar::handle:horizontal:pressed {
    background: #3a539b;
}

/* Hide the left/right arrow buttons */
QScrollBar::sub-line:horizontal, QScrollBar::add-line:horizontal {
    border: none;
    background: none;
    width: 0px;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}</string>
