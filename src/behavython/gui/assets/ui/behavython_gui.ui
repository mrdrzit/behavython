          <string notr="true">QTabWidget::pane {
    background: transparent;
    border: none;
    margin-top: 0px;
}

QTabWidget::tab-bar {
    alignment: center;
}

QTabBar::tab {
    background: #606060;
    color: white;

    min-width: 85px;
    min-height: 30px;
    margin: 2px;

    border: 1px solid #707070;
    border-radius: 10px;

    font: bold 8pt &quot;Arial&quot;;
}

QTabBar::tab:hover {
    background: #4D4D4D;
}

QTabBar::tab:selected {
    background: #2C53A1;
    border: 1px solid #4B7BE0;
}

QTabBar::tab:disabled {
    background: #2B2B2B;
    color: #555555;
    border: 1px solid #333333;
}</string>
