                 <font>
                  <family>Arial</family>
                  <pointsize>8</pointsize>
                  <italic>false</italic>
                  <bold>true</bold>
                 </font>
                </property>
                <property name="styleSheet">
                 <string notr="true">QLabel{color:#FFFFFF;font:8pt&quot;Arial&quot;;font-weight:bold;}</string>
                </property>
                <property name="text">
                 <string notr="true">⚠️ Legacy or unstable video formats detected. Use the button below to reencode the videos to a modern version. Hover the mouse for more information</string>
